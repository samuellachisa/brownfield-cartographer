# LLM configuration for Brownfield Cartographer
# Copy to .env and fill in your values

# Option A: OpenAI or generic (OPENAI_API_KEY + optional base)
# OPENAI_API_KEY=sk-...
# CARTOGRAPHER_LLM_MODEL=gpt-4o-mini
# CARTOGRAPHER_LLM_BASE_URL=https://openrouter.ai/api/v1

# Option B: Groq (or other provider) using LLM_* vars
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_KEY=gsk-your-key-here
LLM_TEXT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional
# CARTOGRAPHER_LLM_RPM=60
# CARTOGRAPHER_EMBEDDING_MODEL=text-embedding-3-small
